#!/usr/bin/env python3
"""
=======================================
PRE-COMMIT HOOK - Conventional Commits
=======================================

Instala en: .git/hooks/pre-commit
Copia este archivo y hazlo ejecutable:
    cp pre-commit .git/hooks/pre-commit
    chmod +x .git/hooks/pre-commit

Este hook:
1. Valida el formato del mensaje de commit
2. Busca IDs de Asana en el mensaje
3. Valida que el branch siga el naming convention
"""

import re
import subprocess
import sys
from pathlib import Path

# ====================
# CONFIGURACION
# ====================

# Tipos validos de conventional commits
VALID_TYPES = [
    "feat", "fix", "docs", "style", "refactor", 
    "test", "chore", "perf", "ci", "build", "revert"
]

# Patron para buscar IDs de Asana en mensajes
ASANA_PATTERN = re.compile(r'ASANA-\d+', re.IGNORECASE)

# Patron para branch naming
BRANCH_PATTERN = re.compile(r'^(feature|fix|hotfix|release|refactor)/([A-Z]+-\d+|task/\d+)', re.IGNORECASE)

# ====================
# FUNCIONES
# ====================

def get_current_branch():
    """Obtiene el branch actual"""
    try:
        result = subprocess.run(
            ['git', 'rev-parse', '--abbrev-ref', 'HEAD'],
            capture_output=True,
            text=True,
            check=True
        )
        return result.stdout.strip()
    except Exception:
        return ""


def get_commit_message():
    """Obtiene el mensaje del commit actual"""
    # Este hook corre despues de que se ingreso el mensaje
    # leemos COMMIT_EDITMSG
    msg_file = Path('.git/COMMIT_EDITMSG')
    if msg_file.exists():
        return msg_file.read_text().strip()
    return ""


def validate_commit_type(message: str) -> tuple[bool, str]:
    """Valida que el commit siga conventional commits"""
    # Buscar el tipo al inicio: tipo(scope): mensaje
    pattern = r'^(\w+)(\(.+\))?: (.+)'
    match = re.match(pattern, message)
    
    if not match:
        return False, "El commit debe seguir el formato: tipo(scope): mensaje"
    
    commit_type = match.group(1)
    if commit_type not in VALID_TYPES:
        return False, f"Tipo invalido: '{commit_type}'. Tipos validos: {', '.join(VALID_TYPES)}"
    
    return True, ""


def find_asana_ids(message: str) -> list[str]:
    """Busca IDs de Asana en el mensaje"""
    return ASANA_PATTERN.findall(message)


def validate_branch_naming(branch: str) -> tuple[bool, str]:
    """Valida que el branch siga el naming convention"""
    if not branch:
        return True, ""  # Skip si no hay branch (ej: detached HEAD)
    
    # Branch main/master siempre es valido
    if branch in ['main', 'master', 'develop', 'dev']:
        return True, ""
    
    if not BRANCH_PATTERN.match(branch):
        return False, f"El branch '{branch}' debe seguir: feature/ASANA-123-descripcion"
    
    return True, ""


def main():
    """Funcion principal del hook"""
    print("[INFO] Validando conventional commits...")
    
    # Obtener branch actual
    branch = get_current_branch()
    
    # Validar branch naming
    valid, error = validate_branch_naming(branch)
    if not valid:
        print(f"[WARN] Branch: {error}")
    
    # Obtener mensaje del commit
    message = get_commit_message()
    
    if not message:
        print("[WARN] No se pudo obtener el mensaje del commit")
        return 0
    
    print(f"[INFO] Mensaje: {message[:60]}...")
    
    # Validar conventional commits
    valid, error = validate_commit_type(message)
    if not valid:
        print(f"[ERROR] {error}")
        print("\nFormato valido: tipo(scope): descripcion")
        print(f"Tipos: {', '.join(VALID_TYPES)}")
        print("Ejemplo: feat(api): agregar nuevo endpoint [ASANA-123]")
        return 1
    
    # Buscar IDs de Asana
    asana_ids = find_asana_ids(message)
    if asana_ids:
        print(f"[OK] Tickets Asana encontrados: {', '.join(asana_ids)}")
    else:
        print("[INFO] No se encontraron IDs de Asana en el mensaje")
    
    print("[OK] Validacion de conventional commits exitosa!")
    return 0


if __name__ == "__main__":
    sys.exit(main())
